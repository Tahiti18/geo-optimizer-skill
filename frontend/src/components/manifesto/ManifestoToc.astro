---
import type { ManifestoSection } from '../../lib/manifestoContent';

interface Props {
  sections: ManifestoSection[];
}

const { sections } = Astro.props;
---

<nav
  class="hidden lg:block sticky top-24 self-start w-64 shrink-0"
  aria-label="Manifesto contents"
>
  <div class="rounded-xl border border-border bg-bg-surface p-5">
    <h2 class="text-[10px] font-mono font-semibold uppercase tracking-wider text-text-muted mb-4">
      Contents
    </h2>
    <ol class="space-y-2.5">
      {sections.map((s) => (
        <li>
          <a
            href={`#${s.id}`}
            class="group flex items-start gap-2 text-sm text-text-secondary hover:text-text-primary transition-colors"
          >
            <span class="font-mono text-[11px] text-accent-teal shrink-0 mt-0.5">
              {s.number}
            </span>
            <span class="leading-snug group-hover:underline underline-offset-2 decoration-border">
              {s.title}
            </span>
          </a>
        </li>
      ))}
    </ol>
  </div>
</nav>

<!-- Mobile TOC: visibile solo su schermi piccoli -->
<nav class="lg:hidden mb-10" aria-label="Manifesto contents">
  <div class="rounded-xl border border-border bg-bg-surface p-5">
    <h2 class="text-[10px] font-mono font-semibold uppercase tracking-wider text-text-muted mb-4">
      Contents
    </h2>
    <ol class="grid grid-cols-1 sm:grid-cols-2 gap-2">
      {sections.map((s) => (
        <li>
          <a
            href={`#${s.id}`}
            class="group flex items-start gap-2 text-sm text-text-secondary hover:text-text-primary transition-colors"
          >
            <span class="font-mono text-[11px] text-accent-teal shrink-0">
              {s.number}
            </span>
            <span class="leading-snug">{s.title}</span>
          </a>
        </li>
      ))}
    </ol>
  </div>
</nav>
