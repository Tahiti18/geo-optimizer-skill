---
interface Props {
  webp: string;
  webpSrcSet?: string;
  png: string;
  pngSrcSet?: string;
  alt: string;
  width: number;
  height: number;
  sizes?: string;
  caption?: string;
  class?: string;
  imgClass?: string;
  captionClass?: string;
  loading?: 'eager' | 'lazy';
  priority?: boolean;
}

const {
  webp,
  webpSrcSet,
  png,
  pngSrcSet,
  alt,
  width,
  height,
  sizes = '100vw',
  caption,
  class: className = '',
  imgClass = '',
  captionClass = 'px-4 py-3 text-xs leading-relaxed text-text-muted',
  loading = 'lazy',
  priority = false,
} = Astro.props;
---

<picture class={className}>
  <source srcset={webpSrcSet ?? webp} sizes={sizes} type="image/webp" />
  <img
    src={png}
    srcset={pngSrcSet}
    sizes={sizes}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding={loading === 'eager' ? 'sync' : 'async'}
    fetchpriority={priority ? 'high' : undefined}
    class={`block h-auto w-full ${imgClass}`}
  />
</picture>
{caption && (
  <figcaption class={captionClass}>
    {caption}
  </figcaption>
)}
