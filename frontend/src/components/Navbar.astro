---
const version = "v4.11.1";
const links = [
  { label: "Audit", href: "/" },
  { label: "Compare", href: "/compare/" },
  { label: "Analyze", href: "/analyze-competitors/" },
];

const moreLinks = [
  { label: "Pricing", href: "/pricing/" },
  { label: "Research", href: "/research/" },
  { label: "Roadmap", href: "/roadmap/" },
  { label: "Manifesto", href: "/manifesto/" },
];
---

<nav class="sticky top-0 z-50 bg-bg-base/90 backdrop-blur-md border-b border-border">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 shrink-0">
      <svg width="28" height="28" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect width="48" height="48" rx="11" fill="#0D9488"/>
        <path d="M11.74 13.71 A16 16 0 1 1 11.74 34.29" stroke="white" stroke-width="2.8" stroke-linecap="round"/>
        <path d="M8 24 C12 14 18 34 24 24 C30 14 36 34 40 24" stroke="white" stroke-width="2.1" stroke-linecap="round" stroke-opacity="0.72"/>
      </svg>
      <span class="font-display font-bold text-base tracking-tight">
        <span class="text-accent-teal">Geo</span><span class="text-text-primary">Ready</span>
      </span>
      <span class="font-mono text-[10px] px-1.5 py-0.5 rounded bg-bg-subtle text-text-secondary border border-border">{version}</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {links.map((l) => (
        <a
          href={l.href}
          class="text-sm font-medium text-text-secondary hover:text-text-primary transition-colors"
        >
          {l.label}
        </a>
      ))}
      <span class="w-px h-4 bg-border"></span>
      <div class="relative">
        <button
          id="more-menu-btn"
          class="text-sm font-medium text-text-secondary hover:text-text-primary transition-colors flex items-center gap-1"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="more-menu"
        >
          More
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div
          id="more-menu"
          role="menu"
          aria-labelledby="more-menu-btn"
          class="absolute top-full right-0 mt-2 w-40 bg-bg-surface border border-border rounded-lg shadow-lg opacity-0 invisible transition-all duration-150"
        >
          {moreLinks.map((l) => (
            <a
              href={l.href}
              role="menuitem"
              class="block px-4 py-2 text-sm text-text-secondary hover:text-text-primary hover:bg-bg-subtle transition-colors first:rounded-t-lg last:rounded-b-lg"
            >
              {l.label}
            </a>
          ))}
        </div>
      </div>
      <span class="w-px h-4 bg-border"></span>
      <a
        href="https://github.com/Auriti-Labs/geo-optimizer-skill"
        target="_blank"
        rel="noopener"
        class="text-sm font-medium text-text-secondary hover:text-text-primary transition-colors flex items-center gap-1.5"
      >
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        GitHub
      </a>
    </div>

    <button
      id="mobile-menu-btn"
      class="md:hidden p-3 border border-border rounded-md text-text-secondary hover:text-text-primary"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="menu-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="md:hidden hidden border-t border-border bg-bg-surface">
    <div class="px-6 py-4 flex flex-col gap-1">
      {links.map((l) => (
        <a href={l.href} class="py-2 text-sm font-medium text-text-secondary hover:text-text-primary border-b border-border last:border-0">
          {l.label}
        </a>
      ))}
      {moreLinks.map((l) => (
        <a href={l.href} class="py-2 text-sm font-medium text-text-secondary hover:text-text-primary border-b border-border last:border-0">
          {l.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  // Menu mobile
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon');

  if (btn && menu && icon) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
      icon.innerHTML = isOpen
        ? '<line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>'
        : '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>';
    });
  }

  // Dropdown More — accessibile da tastiera e hover
  const moreBtn = document.getElementById('more-menu-btn');
  const moreMenu = document.getElementById('more-menu');

  function openMore() {
    moreMenu?.classList.remove('opacity-0', 'invisible');
    moreMenu?.classList.add('opacity-100', 'visible');
    moreBtn?.setAttribute('aria-expanded', 'true');
  }

  function closeMore() {
    moreMenu?.classList.add('opacity-0', 'invisible');
    moreMenu?.classList.remove('opacity-100', 'visible');
    moreBtn?.setAttribute('aria-expanded', 'false');
  }

  if (moreBtn && moreMenu) {
    const wrapper = moreBtn.parentElement!;

    // Hover
    wrapper.addEventListener('mouseenter', openMore);
    wrapper.addEventListener('mouseleave', closeMore);

    // Tastiera: Enter/Space apre, Escape chiude
    moreBtn.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        const isOpen = moreBtn.getAttribute('aria-expanded') === 'true';
        isOpen ? closeMore() : openMore();
      }
      if (e.key === 'Escape') closeMore();
    });

    // Chiudi al click fuori
    document.addEventListener('click', (e) => {
      if (!wrapper.contains(e.target as Node)) closeMore();
    });

    // Escape dall'interno dei menu item
    moreMenu.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') {
        closeMore();
        moreBtn.focus();
      }
    });
  }
</script>
