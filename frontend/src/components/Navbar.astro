---
const version = "v4.11.1";

// Visibili sempre in desktop
const primaryLinks = [
  { label: "Audit", href: "/" },
  { label: "Compare", href: "/compare/" },
  { label: "Analyze", href: "/analyze-competitors/" },
];

// Nascoste nel dropdown "More"
const moreLinks = [
  { label: "Research", href: "/research/", desc: "Princeton KDD + AutoGEO ICLR" },
  { label: "Roadmap", href: "/roadmap/", desc: "What's coming next" },
  { label: "Manifesto", href: "/manifesto/", desc: "Why we built GeoReady" },
];

// Promosso fuori dal dropdown ma fuori da primary
const featuredLink = { label: "Pricing", href: "/pricing/" };
---

<nav id="floating-nav" class="sticky top-0 z-50 pt-3 pb-2 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div id="nav-pill" class="h-14 pl-4 pr-2 sm:pl-5 sm:pr-3 flex items-center justify-between gap-3 rounded-full border border-border/60 bg-bg-base/40 backdrop-blur-2xl backdrop-saturate-150 shadow-[0_4px_20px_-6px_rgba(0,0,0,0.10)] transition-all duration-300">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 shrink-0">
      <svg width="28" height="28" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect width="48" height="48" rx="11" fill="#0D9488"/>
        <path d="M11.74 13.71 A16 16 0 1 1 11.74 34.29" stroke="white" stroke-width="2.8" stroke-linecap="round"/>
        <path d="M8 24 C12 14 18 34 24 24 C30 14 36 34 40 24" stroke="white" stroke-width="2.1" stroke-linecap="round" stroke-opacity="0.72"/>
      </svg>
      <span class="font-display font-bold text-base tracking-tight">
        <span class="text-accent-teal">Geo</span><span class="text-text-primary">Ready</span>
      </span>
      <span class="hidden sm:inline font-mono text-[10px] px-1.5 py-0.5 rounded bg-bg-subtle text-text-secondary border border-border">{version}</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-0.5">
      {primaryLinks.map((l) => (
        <a
          href={l.href}
          data-nav-link
          class="nav-link relative px-3 py-1.5 rounded-full text-[13px] font-medium text-text-secondary hover:text-text-primary transition-colors"
        >
          <span class="relative z-10">{l.label}</span>
        </a>
      ))}

      <!-- Featured: Pricing pill -->
      <a
        href={featuredLink.href}
        data-nav-link
        class="nav-link ml-1 px-3 py-1.5 rounded-full text-[13px] font-medium text-accent-teal hover:bg-accent-teal/10 transition-colors flex items-center gap-1.5"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-accent-teal animate-pulse"></span>
        <span class="relative z-10">{featuredLink.label}</span>
      </a>

      <!-- More dropdown -->
      <div class="relative ml-0.5">
        <button
          id="more-menu-btn"
          class="px-3 py-1.5 rounded-full text-[13px] font-medium text-text-secondary hover:text-text-primary hover:bg-bg-subtle transition-colors flex items-center gap-1"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="more-menu"
        >
          More
          <svg id="more-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="transition-transform duration-200">
            <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div
          id="more-menu"
          role="menu"
          aria-labelledby="more-menu-btn"
          class="absolute top-full right-0 mt-3 w-64 bg-bg-surface/95 backdrop-blur-xl border border-border rounded-2xl shadow-[0_12px_40px_-8px_rgba(0,0,0,0.18)] opacity-0 invisible translate-y-1 transition-all duration-200 overflow-hidden p-1"
        >
          {moreLinks.map((l) => (
            <a
              href={l.href}
              role="menuitem"
              class="flex flex-col gap-0.5 px-3 py-2.5 rounded-xl text-sm hover:bg-bg-subtle transition-colors"
            >
              <span class="font-medium text-text-primary">{l.label}</span>
              <span class="text-xs text-text-secondary">{l.desc}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Divider -->
      <span class="mx-2 h-5 w-px bg-border" aria-hidden="true"></span>

      <!-- Right cluster -->
      <div class="flex items-center gap-1.5">
        <a
          href="https://github.com/Auriti-Labs/geo-optimizer-skill"
          target="_blank"
          rel="noopener"
          aria-label="GitHub repository"
          class="w-8 h-8 flex items-center justify-center rounded-full text-text-secondary hover:text-text-primary hover:bg-bg-subtle transition-colors"
        >
          <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
        </a>
        <a
          href="https://app.geoready.dev/signup"
          class="group px-3.5 py-1.5 rounded-full bg-accent-teal text-white text-[13px] font-semibold hover:bg-accent-teal-dark transition-all shadow-[0_4px_12px_-2px_rgba(13,148,136,0.45)] hover:shadow-[0_6px_16px_-2px_rgba(13,148,136,0.55)] hover:-translate-y-px flex items-center gap-1.5"
        >
          <span>Get started</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:translate-x-0.5" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Mobile burger — Pulse-themed: arc + wave morphing into X -->
    <button
      id="mobile-menu-btn"
      class="md:hidden relative w-10 h-10 flex items-center justify-center rounded-lg text-text-primary hover:bg-bg-subtle transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="sr-only">Menu</span>
      <svg id="burger-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="transition-transform duration-300">
        <!-- Arc (top) — morphs to X stroke 1 -->
        <path id="burger-arc" d="M5 8 A 7 7 0 0 1 19 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" class="transition-all duration-300"/>
        <!-- Wave (middle) — fades out -->
        <path id="burger-wave" d="M4 13 C 7 10 9 16 12 13 C 15 10 17 16 20 13" stroke="#0D9488" stroke-width="2" stroke-linecap="round" fill="none" class="transition-all duration-300"/>
        <!-- Bottom line — morphs to X stroke 2 -->
        <line id="burger-base" x1="6" y1="18" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="transition-all duration-300"/>
      </svg>
    </button>
    </div>
  </div>

  <!-- end inner container -->
</nav>

<!-- Mobile fullscreen overlay — OUTSIDE nav to avoid backdrop-filter containing block bug -->
<div
  id="mobile-menu"
  class="md:hidden hidden fixed inset-x-0 top-[76px] bottom-0 z-[60] bg-bg-base overflow-y-auto overscroll-contain"
  aria-hidden="true"
>
    <div class="px-5 pt-5 pb-10">

      <!-- Featured CTA -->
      <a
        href="/pricing/"
        data-mobile-link
        class="group flex items-center justify-between gap-3 rounded-xl border border-accent-teal/30 bg-accent-teal/10 px-4 py-3.5 mb-5 hover:border-accent-teal/60 transition-colors"
      >
        <div class="min-w-0">
          <div class="flex items-center gap-1.5 mb-0.5">
            <span class="w-1.5 h-1.5 rounded-full bg-accent-teal animate-pulse"></span>
            <span class="text-[9px] font-mono uppercase tracking-[0.15em] text-accent-teal">Featured</span>
          </div>
          <p class="font-display text-[15px] font-semibold text-text-primary leading-tight">Pricing — plans from $0</p>
          <p class="text-[11px] text-text-secondary mt-0.5 truncate">Free audit · Pro · Studio · Agency</p>
        </div>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-accent-teal group-hover:translate-x-0.5 transition-transform" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>

      <!-- Section: Tools -->
      <p class="text-[10px] font-mono uppercase tracking-[0.15em] text-text-muted mb-1.5 mt-4 px-1">Tools</p>
      <div class="flex flex-col mb-2">
        {primaryLinks.map((l) => (
          <a
            href={l.href}
            data-mobile-link
            class="flex items-center justify-between py-3 px-1 text-[15px] font-medium text-text-primary border-b border-border last:border-0 hover:text-accent-teal transition-colors"
          >
            <span>{l.label}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted" aria-hidden="true">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </a>
        ))}
      </div>

      <!-- Section: Learn more -->
      <p class="text-[10px] font-mono uppercase tracking-[0.15em] text-text-muted mb-1.5 mt-5 px-1">Learn more</p>
      <div class="flex flex-col mb-2">
        {moreLinks.map((l) => (
          <a
            href={l.href}
            data-mobile-link
            class="flex flex-col gap-0.5 py-3 px-1 border-b border-border last:border-0 hover:bg-bg-subtle/50 transition-colors"
          >
            <span class="text-[15px] font-medium text-text-primary">{l.label}</span>
            <span class="text-[11px] text-text-secondary">{l.desc}</span>
          </a>
        ))}
      </div>

      <!-- Bottom CTAs -->
      <div class="flex flex-col gap-2.5 mt-7 pt-5 border-t border-border">
        <a
          href="https://app.geoready.dev/signup"
          data-mobile-link
          class="w-full text-center py-3 rounded-lg bg-accent-teal text-white font-semibold text-sm hover:bg-accent-teal-dark transition-colors"
        >
          Get started — free
        </a>
        <a
          href="https://app.geoready.dev/login"
          data-mobile-link
          class="w-full text-center py-3 rounded-lg border border-border text-text-primary font-semibold text-sm hover:bg-bg-subtle transition-colors"
        >
          Log in
        </a>
        <a
          href="https://github.com/Auriti-Labs/geo-optimizer-skill"
          target="_blank"
          rel="noopener"
          class="flex items-center justify-center gap-2 py-2.5 text-xs text-text-secondary hover:text-text-primary transition-colors"
        >
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          View on GitHub
        </a>
      </div>
    </div>
</div>

<script>
  // ─── Mobile fullscreen menu ─────────────────────────────────────────────────
  const burgerBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const burgerIcon = document.getElementById('burger-icon');

  function setBurgerOpen(open: boolean) {
    const arc = document.getElementById('burger-arc') as SVGPathElement | null;
    const wave = document.getElementById('burger-wave') as SVGPathElement | null;
    const base = document.getElementById('burger-base') as SVGLineElement | null;
    if (!arc || !wave || !base) return;
    if (open) {
      // Morph arc → diagonal X line, wave fades, base → opposite diagonal
      arc.setAttribute('d', 'M6 6 L 18 18');
      wave.style.opacity = '0';
      base.setAttribute('x1', '18');
      base.setAttribute('y1', '6');
      base.setAttribute('x2', '6');
      base.setAttribute('y2', '18');
    } else {
      arc.setAttribute('d', 'M5 8 A 7 7 0 0 1 19 8');
      wave.style.opacity = '';
      base.setAttribute('x1', '6');
      base.setAttribute('y1', '18');
      base.setAttribute('x2', '18');
      base.setAttribute('y2', '18');
    }
  }

  function openMobile() {
    if (!mobileMenu) return;
    mobileMenu.classList.remove('hidden');
    mobileMenu.setAttribute('aria-hidden', 'false');
    burgerBtn?.setAttribute('aria-expanded', 'true');
    setBurgerOpen(true);
    document.body.style.overflow = 'hidden';
  }

  function closeMobile() {
    if (!mobileMenu) return;
    mobileMenu.classList.add('hidden');
    mobileMenu.setAttribute('aria-hidden', 'true');
    burgerBtn?.setAttribute('aria-expanded', 'false');
    setBurgerOpen(false);
    document.body.style.overflow = '';
  }

  burgerBtn?.addEventListener('click', () => {
    const isOpen = burgerBtn.getAttribute('aria-expanded') === 'true';
    isOpen ? closeMobile() : openMobile();
  });

  // Chiudi al tap su un link mobile
  document.querySelectorAll('[data-mobile-link]').forEach((link) => {
    link.addEventListener('click', closeMobile);
  });

  // Escape chiude
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && burgerBtn?.getAttribute('aria-expanded') === 'true') {
      closeMobile();
    }
  });

  // Chiudi se viewport cresce oltre md (768px)
  const mq = window.matchMedia('(min-width: 768px)');
  mq.addEventListener('change', (e) => {
    if (e.matches) closeMobile();
  });

  // ─── Desktop "More" dropdown ─────────────────────────────────────────────────
  const moreBtn = document.getElementById('more-menu-btn');
  const moreMenu = document.getElementById('more-menu');
  const moreChevron = document.getElementById('more-chevron');

  function openMore() {
    moreMenu?.classList.remove('opacity-0', 'invisible', 'translate-y-1');
    moreMenu?.classList.add('opacity-100', 'visible', 'translate-y-0');
    moreBtn?.setAttribute('aria-expanded', 'true');
    moreChevron?.style.setProperty('transform', 'rotate(180deg)');
  }

  function closeMore() {
    moreMenu?.classList.add('opacity-0', 'invisible', 'translate-y-1');
    moreMenu?.classList.remove('opacity-100', 'visible', 'translate-y-0');
    moreBtn?.setAttribute('aria-expanded', 'false');
    moreChevron?.style.setProperty('transform', '');
  }

  if (moreBtn && moreMenu) {
    const wrapper = moreBtn.parentElement!;

    wrapper.addEventListener('mouseenter', openMore);
    wrapper.addEventListener('mouseleave', closeMore);

    moreBtn.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        const isOpen = moreBtn.getAttribute('aria-expanded') === 'true';
        isOpen ? closeMore() : openMore();
      }
      if (e.key === 'Escape') closeMore();
    });

    document.addEventListener('click', (e) => {
      if (!wrapper.contains(e.target as Node)) closeMore();
    });

    moreMenu.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') {
        closeMore();
        moreBtn.focus();
      }
    });
  }

  // ─── Floating pill scroll-shrink ─────────────────────────────────────────────
  const floatNav = document.getElementById('floating-nav');
  const navPill = document.getElementById('nav-pill');

  function updateNavScroll() {
    if (!floatNav || !navPill) return;
    const scrolled = window.scrollY > 8;
    if (scrolled) {
      floatNav.classList.remove('pt-3');
      floatNav.classList.add('pt-2');
      navPill.classList.remove('h-14');
      navPill.classList.add('h-12', 'shadow-[0_10px_32px_-8px_rgba(0,0,0,0.22)]');
    } else {
      floatNav.classList.add('pt-3');
      floatNav.classList.remove('pt-2');
      navPill.classList.add('h-14');
      navPill.classList.remove('h-12', 'shadow-[0_10px_32px_-8px_rgba(0,0,0,0.22)]');
    }
  }

  updateNavScroll();
  window.addEventListener('scroll', updateNavScroll, { passive: true });

  // ─── Active link highlight (current page pill) ───────────────────────────────
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]');
  const currentPath = window.location.pathname.replace(/\/$/, '') || '/';
  navLinks.forEach((link) => {
    const href = link.getAttribute('href')?.replace(/\/$/, '') || '';
    if (href === currentPath) {
      link.classList.add('bg-bg-subtle', 'text-text-primary');
      link.setAttribute('aria-current', 'page');
    }
  });
</script>
