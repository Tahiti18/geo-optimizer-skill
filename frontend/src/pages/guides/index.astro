---
import Shell from '../../components/Shell.astro';
import NewsletterSignup from '../../components/NewsletterSignup';
import VisualStage from '../../components/VisualStage.astro';
import { marketingVisuals } from '../../lib/marketingVisuals';

// Guides hub. Kept as a simple static index — add one entry per guide here.
const guides = [
  {
    href: '/guides/ai-citations-check/',
    title: 'How to check if AI engines cite your brand (ChatGPT, Perplexity)',
    description:
      'A practical method to find out whether AI answers mention your brand and cite your domain as a source — manually, with the free checker, and with ongoing monitoring.',
    readingTime: '8 min read',
  },
  {
    href: '/guides/entity-authority/',
    title: 'Entity-based authority: why five pages beat one strong page',
    description:
      'AI engines map entities and multi-page topic coverage, not keywords. How topic clusters, pillar pages, and hub-and-spoke internal links build the authority that earns citations.',
    readingTime: '9 min read',
  },
  {
    href: '/guides/multimodal-geo/',
    title: 'Multimodal GEO: making images and video citable by AI engines',
    description:
      'Gemini and GPT-4o reach images, video, and audio through their text scaffolding: alt text, captions, VideoObject schema, subtitle tracks, and transcripts. What to add, per medium.',
    readingTime: '8 min read',
  },
  {
    href: '/guides/generative-engine-optimization/',
    title: 'Generative Engine Optimization: a practical guide to GEO',
    description:
      'What GEO is, why it matters now, and how to make your site crawlable, understandable, and citable by AI answer engines. The pillar guide to the discipline behind AI SEO.',
    readingTime: '11 min read',
  },
  {
    href: '/guides/what-is-llms-txt/',
    title: 'What is llms.txt? A practical guide with example',
    description:
      'What llms.txt is, how it differs from robots.txt, what to include, and a concrete example. An orientation file for AI systems — not a confirmed ranking factor.',
    readingTime: '9 min read',
  },
  {
    href: '/guides/appear-in-chatgpt-perplexity/',
    title: 'How to make your website appear in ChatGPT and Perplexity sources',
    description:
      'A practical checklist for becoming citable by AI answer engines — crawlability, llms.txt, structured data, and the content patterns models tend to quote.',
    readingTime: '12 min read',
  },
  {
    href: '/guides/geo-vs-seo/',
    title: 'GEO vs SEO: what changes when AI engines become the interface',
    description:
      'SEO and GEO share technical foundations but diverge in what they optimize for. A guide to the overlap, the differences, and where to focus effort when AI answer engines matter.',
    readingTime: '10 min read',
  },
  {
    href: '/guides/llms-txt-wordpress/',
    title: 'llms.txt for WordPress and AI visibility: a practical guide',
    description:
      'What llms.txt is, what it actually does, and how to implement it on WordPress — manually or with a plugin. Includes format reference and what to include.',
    readingTime: '9 min read',
  },
  {
    href: '/guides/ai-visibility-checklist/',
    title: 'AI visibility checklist: how to make your website easier to find, cite, and recommend',
    description:
      'All the technical and content signals that affect AI answer engine visibility, organized by category with clear pass/fail criteria. Crawlability, schema, llms.txt, brand signals, and more.',
    readingTime: '14 min read',
  },
];
---

<Shell
  title="Guides — AI Search Visibility & Generative Engine Optimization"
  description="Practical, no-hype guides on making your website visible and citable to AI answer engines like ChatGPT, Perplexity, Claude, and Gemini."
  canonical="https://geoready.dev/guides/"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10 md:py-16">
    {/* Header */}
    <header class="mb-12 overflow-hidden rounded-[--radius-2xl] border border-border bg-bg-surface md:mb-16">
      <div class="grid lg:grid-cols-[minmax(0,0.88fr)_minmax(420px,0.82fr)]">
        <div class="p-6 md:p-10 lg:p-12">
        <div class="flex items-center gap-2 text-[10px] font-mono text-text-muted uppercase tracking-wider">
          <span>GEO Optimizer</span>
          <span class="w-1 h-1 rounded-full bg-text-muted" />
          <span>Guides</span>
        </div>

        <h1 class="mt-4 max-w-3xl font-display text-4xl md:text-5xl font-bold text-text-primary leading-tight tracking-tight">
          AI visibility guides for people who need the system to make sense.
        </h1>

        <p class="mt-5 max-w-2xl text-base md:text-lg text-text-secondary leading-relaxed">
          Practical, research-grounded walkthroughs for making your site visible
          and citable to AI answer engines. No guaranteed-ranking promises — just
          the technical and content signals that help models find and quote you.
        </p>

        <div class="mt-8 grid gap-3 sm:grid-cols-3">
          {[
            ['01', 'Foundations', 'AI SEO, GEO, llms.txt, and crawler access.'],
            ['02', 'Citability', 'How answer engines choose sources and references.'],
            ['03', 'Execution', 'Checklists and implementation paths for real sites.'],
          ].map(([num, label, text]) => (
            <div class="border-l border-accent-teal/30 pl-4">
              <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-accent-teal">{num} {label}</p>
              <p class="mt-1 text-sm leading-relaxed text-text-secondary">{text}</p>
            </div>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap gap-3 text-sm">
          <a href="/research/" class="text-accent-teal hover:text-accent-teal-dark transition-colors">Research foundation</a>
          <span class="text-text-muted">·</span>
          <a href="/manifesto/" class="text-accent-teal hover:text-accent-teal-dark transition-colors">Manifesto</a>
          <span class="text-text-muted">·</span>
          <a href="/tools/ai-citation-checker/" class="text-accent-teal hover:text-accent-teal-dark transition-colors">Citation checker</a>
        </div>
      </div>

        <div class="border-t border-border bg-bg-subtle p-4 lg:border-l lg:border-t-0">
        <VisualStage
          visual={marketingVisuals.retrievalMapV2}
          variant="paper"
          label="Guide map"
          eyebrow="Learning path"
          sizes="(min-width: 1024px) 42vw, 100vw"
          loading="eager"
          priority
          imgClass="aspect-[16/9] object-cover"
          metrics={[
            { label: 'Start', value: 'Access' },
            { label: 'Build', value: 'Entity clarity' },
            { label: 'Measure', value: 'Citation' },
          ]}
          chips={['Guides', 'Research', 'Tools']}
        />
        </div>
      </div>
    </header>

    {/* Guide list */}
    <ul class="grid gap-4 md:grid-cols-2">
      {guides.map((g) => (
        <li>
          <a
            href={g.href}
            class="group block h-full rounded-xl border border-border bg-bg-surface p-5 md:p-6 transition-colors hover:border-accent-teal/30"
          >
            <p class="mb-4 text-xs font-mono text-text-muted">{g.readingTime}</p>
            <h2 class="font-display text-lg md:text-xl font-semibold text-text-primary leading-snug group-hover:text-accent-teal">
              {g.title}
            </h2>
            <p class="mt-2 text-sm md:text-base text-text-secondary leading-relaxed">
              {g.description}
            </p>
          </a>
        </li>
      ))}
    </ul>

    {/* Tools — strumenti gratuiti collegati alle guide */}
    <section class="mt-12 border-t border-border pt-10 md:mt-16 md:pt-12">
      <div class="grid gap-6 md:grid-cols-[minmax(0,0.55fr)_minmax(0,1fr)] md:items-start">
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-accent-teal">From guide to action</p>
          <h2 class="mt-2 font-display text-2xl font-semibold text-text-primary">Free tools</h2>
          <p class="mt-3 text-sm leading-relaxed text-text-secondary">
            Use the tools when a guide turns into an implementation task.
          </p>
        </div>
      <ul class="space-y-4">
        <li>
          <a
            href="/tools/llms-txt-generator/"
            class="block rounded-xl border border-border bg-bg-surface p-5 md:p-6 transition-colors hover:border-accent-teal/30"
          >
            <h3 class="font-display text-base md:text-lg font-semibold text-text-primary leading-snug">
              Free llms.txt generator
            </h3>
            <p class="mt-2 text-sm md:text-base text-text-secondary leading-relaxed">
              Generate a starter llms.txt from your sitemap — categorized, editable Markdown you can download and publish at your domain root.
            </p>
            <p class="mt-3 text-xs font-mono text-text-muted">Tool</p>
          </a>
        </li>
      </ul>
      </div>
    </section>

    <section class="mt-12">
      <NewsletterSignup
        client:visible
        source="newsletter-guides"
        title="New guides + the State of GEO report, by email"
        detail="Occasional, substantive emails: new GEO guides, benchmark findings, and the State of GEO 2026 report when it ships. No spam."
      />
    </section>
  </div>
</Shell>
