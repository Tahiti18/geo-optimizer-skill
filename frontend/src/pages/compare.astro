---
import Shell from '../components/Shell.astro';
import CompareContainer from '../components/compare/CompareContainer';
import MarketingVisual from '../components/MarketingVisual.astro';
import { marketingVisuals } from '../lib/marketingVisuals';
---

<Shell
  title="Compare AI Search Visibility — Two Sites Side by Side"
  description="Run a free head-to-head GEO audit. Enter two URLs and compare AI search visibility, citability, and technical signals for ChatGPT, Perplexity, and Claude."
  canonical="https://geoready.dev/compare/"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10 md:py-16">
    {/* Static hero — visible to crawlers */}
    <header class="mb-8 grid gap-8 lg:grid-cols-[minmax(0,0.82fr)_minmax(360px,0.78fr)] lg:items-center">
      <div class="max-w-2xl">
        <div class="flex items-center gap-2 text-[10px] font-mono text-text-muted uppercase tracking-wider">
          <span>GEO Optimizer</span>
          <span class="w-1 h-1 rounded-full bg-text-muted" />
          <span>Compare</span>
        </div>

        <h1 class="mt-3 font-display text-3xl md:text-4xl font-bold text-text-primary leading-tight tracking-tight">
          Compare AI Search Visibility
        </h1>

        <p class="mt-4 text-base text-text-secondary leading-relaxed max-w-2xl">
          Enter two URLs below and run a free head-to-head GEO audit. See which site is more
          visible to AI answer engines like ChatGPT, Perplexity, and Claude — scored across the
          same 8 signal categories, side by side.
        </p>

        <a href="#compare-form" class="mt-5 inline-flex items-center gap-2 rounded-lg bg-accent-teal px-5 py-2.5 text-sm font-medium text-white hover:bg-accent-teal-dark transition-colors">
          Compare two sites
        </a>
      </div>

      <figure class="overflow-hidden rounded-[--radius-xl] border border-border bg-bg-surface shadow-[0_24px_70px_-42px_rgba(15,23,42,0.6)]">
        <MarketingVisual
          {...marketingVisuals.commandCenter}
          sizes="(min-width: 1024px) 40vw, 100vw"
          loading="eager"
          priority
          imgClass="aspect-[16/9] object-cover"
          captionClass="border-t border-border px-4 py-3 text-xs leading-relaxed text-text-muted"
        />
      </figure>
    </header>

    {/* Static info section — visible to crawlers */}
    <section class="mb-10 max-w-2xl">
      <h2 class="text-sm font-mono font-semibold uppercase tracking-wider text-text-muted mb-3">
        How comparison works
      </h2>
      <p class="text-sm text-text-secondary leading-relaxed mb-3">
        The comparison benchmarks each site across the same 8 signal categories used in the standard GEO audit.
      </p>
      <ul class="space-y-2">
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent-teal mt-1.5 shrink-0" aria-hidden="true" />
          GEO Score across 8 signal categories
        </li>
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent-teal mt-1.5 shrink-0" aria-hidden="true" />
          Citability score (47-method suite)
        </li>
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent-teal mt-1.5 shrink-0" aria-hidden="true" />
          Technical signal readiness
        </li>
        <li class="text-sm text-text-secondary flex items-start gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent-teal mt-1.5 shrink-0" aria-hidden="true" />
          AI search visibility for ChatGPT, Perplexity, and Claude
        </li>
      </ul>
      <p class="mt-4 text-sm text-text-secondary">
        Need to evaluate more than two domains? <a href="/analyze-competitors/" class="text-accent-teal hover:underline">Use competitor analysis</a>.
      </p>
    </section>

    {/* Interactive tool — hydrated by React */}
    <div id="compare-form" class="scroll-mt-24">
      <CompareContainer client:only="react" />
    </div>
  </div>

  {/* Page-specific schema */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Compare AI Search Visibility — Two Sites Side by Side",
    "description": "Run a free head-to-head GEO audit. Enter two URLs and compare AI search visibility, citability, and technical signals for ChatGPT, Perplexity, and Claude.",
    "url": "https://geoready.dev/compare/",
    "author": {
      "@type": "Organization",
      "name": "Auriti Labs",
      "url": "https://github.com/Auriti-Labs"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Auriti Labs",
      "url": "https://github.com/Auriti-Labs"
    },
    "datePublished": "2026-05-12",
    "dateModified": "2026-05-26",
    "mainEntity": {
      "@type": "WebApplication",
      "name": "GEO Optimizer Comparison Tool",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Web",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "featureList": [
        "Side-by-side GEO score comparison",
        "Citability benchmarking",
        "Technical signal analysis",
        "AI visibility scoring"
      ]
    }
  })} />
</Shell>
