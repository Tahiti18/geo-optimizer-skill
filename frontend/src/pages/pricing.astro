---
import Shell from '../components/Shell.astro';
import MonitorSurface from '../components/product/MonitorSurface.astro';

const selfServePlans = [
  {
    id: 'free',
    name: 'Free',
    price: '$0',
    period: 'forever',
    status: 'Available now',
    statusStyle: 'bg-accent-success/10 text-accent-success',
    description: 'Single-URL audit with a full GEO score, top recommendations, and partial category breakdown. No account required.',
    cta: 'Start free audit',
    ctaHref: '/',
    ctaStyle: 'border border-border text-text-primary hover:bg-bg-subtle',
    recommended: false,
    features: [
      '5 audits per day',
      'GEO score 0–100',
      'Partial report — 3 of 8 categories',
      'Top 3 recommendations',
      'CLI (MIT, unlimited)',
    ],
  },
  {
    id: 'pro',
    name: 'Pro',
    price: '$19',
    period: '/month',
    status: 'Founding price',
    statusStyle: 'bg-accent-teal/10 text-accent-teal',
    description: 'Full reports, weekly monitoring for one domain, score history, and regression alerts. For developers and consultants managing one site.',
    cta: 'Start with Pro',
    ctaHref: 'https://app.geoready.dev/signup?plan=pro',
    ctaStyle: 'bg-accent-teal text-white hover:bg-accent-teal-dark',
    recommended: true,
    features: [
      'Unlimited audits',
      'Full 8-category GEO report',
      '1 domain — weekly monitoring',
      '30-audit score history',
      'Regression alerts (when your score moves by 5 points or more)',
      'PDF export',
      'API access (Bearer token)',
    ],
  },
  {
    id: 'studio',
    name: 'Studio',
    price: '$49',
    period: '/month',
    status: 'Founding price',
    statusStyle: 'bg-accent-teal/10 text-accent-teal',
    description: 'AI citation tracking, multi-site daily monitoring, unbranded PDF exports, and competitor comparison. For consultants and agencies managing a portfolio.',
    cta: 'Start with Studio',
    ctaHref: 'https://app.geoready.dev/signup?plan=studio',
    ctaStyle: 'border border-border text-text-primary hover:bg-bg-subtle',
    recommended: false,
    features: [
      'Everything in Pro',
      'AI citation tracking — 5 automated checks/day (Perplexity)',
      '15 domains — daily monitoring',
      '12-month score history',
      'Unbranded PDF export (removes GeoReady footer and badge)',
      'Custom-logo white-label: roadmap',
      'Competitor comparison',
      'Batch audit — 50 URLs',
      'Priority support',
    ],
  },
];

const scalePlans = [
  {
    id: 'agency',
    name: 'Agency',
    price: '$89',
    period: '/month',
    status: 'Founding price',
    statusStyle: 'bg-accent-teal/10 text-accent-teal',
    description: 'Team workspace, 50-domain daily portfolio monitoring, AI answer snapshots, and unlimited batch audits.',
    cta: 'Start with Agency',
    ctaHref: 'https://app.geoready.dev/signup?plan=agency',
    features: [
      'Everything in Studio',
      '50 domains — daily monitoring',
      '24-month score history',
      'Team workspace (owner / editor / viewer)',
      'Unlimited batch audits',
      'AI answer snapshots (Perplexity automated; ChatGPT and Google via manual paste)',
      'Citation quality scoring',
    ],
  },
  {
    id: 'enterprise',
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    status: 'Talk to us',
    statusStyle: 'bg-bg-subtle text-text-muted border border-border',
    description: 'SLA, dedicated account manager, on-premise deployment, hourly monitoring, and custom integrations.',
    cta: 'Contact sales',
    ctaHref: '/early-access/',
    features: [
      'Everything in Agency',
      'Unlimited domains',
      'Hourly monitoring',
      'SLA',
      'On-premise deployment',
      'Webhooks / Slack / CMS integrations',
      'Dedicated account manager',
      'Custom onboarding',
    ],
  },
];

const comparisonRows: [string, string, string, string, string][] = [
  ['GEO score (0–100)',      '✓',       '✓',        '✓',        '✓'],
  ['Partial report (3/8)',   '✓',       '—',        '—',        '—'],
  ['Full 8-category report', '—',       '✓',        '✓',        '✓'],
  ['Audits per day',         '5',       '∞',        '∞',        '∞'],
  ['Domain monitoring',      '—',       '1 / week', '15 / day', '50 / day'],
  ['Score history',          '—',       '30 audits','12 months','24 months'],
  ['Regression alerts',      '—',       '✓',        '✓',        '✓'],
  ['PDF export',             '—',       '✓',        '✓',        '✓'],
  ['Unbranded PDF export',   '—',       '—',        '✓',        '✓'],
  ['Custom-logo white-label','—',       '—',        'roadmap',  'roadmap'],
  ['Competitor comparison',  '—',       '—',        '✓',        '✓'],
  ['Bulk audit',             '—',       '—',        '50 URLs',  '∞'],
  ['Team workspace',         '—',       '—',        '—',        '✓'],
  ['AI search snapshots',    '—',       '—',        '5 runs/day', '✓'],
  ['API access',             '—',       '✓',        '✓',        '✓'],
  ['CLI (MIT)',               '✓',       '✓',        '✓',        '✓'],
];

const faqs = [
  {
    q: 'Is the free audit really free?',
    a: 'Yes. The web audit requires no account, no credit card, and no signup. You get a full GEO score and three category breakdowns immediately. The CLI is MIT-licensed and free to use without limits.',
  },
  {
    q: 'Do I need to register to use the free audit?',
    a: 'No. Just enter a URL and run the audit. Email capture is optional and only used to unlock the full 8-category report.',
  },
  {
    q: 'What does Pro add that Free does not?',
    a: 'Pro adds continuity. The free audit is a one-shot snapshot. Pro monitors your domain weekly, tracks score history over time, and sends alerts when your GEO score drops. It also includes PDF export and API access.',
  },
  {
    q: 'Are paid plans available right now?',
    a: 'Yes. Pick a plan, create an account, and pay — your subscription is active immediately. No sales call, no waitlist. Payments are processed securely by Stripe.',
  },
  {
    q: 'What is the founding price?',
    a: 'The current prices are a founding rate for early members. They are locked for the life of the subscription as long as it stays active. The public list price will be higher later.',
  },
  {
    q: 'Will the CLI remain open source?',
    a: 'Yes. The CLI (geo-optimizer-skill on PyPI) is MIT-licensed and will remain free forever. SaaS plans add server-side continuity features the CLI cannot provide on its own.',
  },
  {
    q: 'Is there a free trial for paid plans?',
    a: 'There is no time-limited trial. The Free plan is the permanent baseline — it returns real audit results without commitment. Paid plans add monitoring and team features on top.',
  },
  {
    q: 'Can I cancel at any time?',
    a: 'Yes. You can cancel from your account settings at any time, with no lock-in or penalties.',
  },
];
---

<Shell
  title="GeoReady Pricing — Free AI Audit, Pro Monitoring & Alerts"
  description="The GEO audit is free, no account required. Pro adds weekly monitoring, full reports, score history, and alerts. Studio and Agency add multi-site daily monitoring and unbranded exports."
  canonical="https://geoready.dev/pricing/"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 md:py-16">

    {/* Hero */}
    <header class="mb-16 overflow-hidden border border-border bg-bg-surface">
      <div class="grid lg:grid-cols-[minmax(0,0.82fr)_minmax(420px,0.78fr)]">
        <div class="p-7 sm:p-10 lg:p-12">
          <div class="flex items-center gap-2 text-[10px] font-mono text-text-muted uppercase tracking-wider">
            <span>GeoReady</span>
            <span class="w-1 h-1 rounded-full bg-text-muted"></span>
            <span>Pricing</span>
          </div>
          <h1 class="mt-4 max-w-3xl font-display text-4xl font-bold text-text-primary leading-tight tracking-tight md:text-5xl">
            Free GEO audit, forever. Pay only when you need monitoring.
          </h1>
          <p class="mt-5 max-w-2xl text-base text-text-secondary leading-relaxed">
            Run a full GEO score on any URL with no account and no card — every time you want.
            Paid plans add what a one-shot audit can't: weekly monitoring, score history, regression
            alerts, exports, and team workflows.
          </p>

          <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
              href="/"
              data-cta="pricing_hero_free_audit"
              class="inline-flex items-center justify-center rounded-[--radius-md] bg-accent-teal px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-teal-dark"
            >
              Start free audit →
            </a>
            <span class="text-sm text-text-muted">
              No time trial. No card required for Free. Cancel anytime.
            </span>
          </div>

          <div class="mt-8 grid gap-3 sm:grid-cols-3">
            <div class="border-l border-accent-teal/30 pl-4">
              <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-accent-teal">Free</p>
              <p class="mt-1 text-sm text-text-secondary">Single-URL audit, no account.</p>
            </div>
            <div class="border-l border-accent-teal/30 pl-4">
              <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-accent-teal">Pro</p>
              <p class="mt-1 text-sm text-text-secondary">$19/month founding price.</p>
            </div>
            <div class="border-l border-accent-teal/30 pl-4">
              <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-accent-teal">Studio</p>
              <p class="mt-1 text-sm text-text-secondary">Multi-site monitoring and exports.</p>
            </div>
          </div>

          <p class="mt-8 max-w-2xl text-sm text-text-muted leading-relaxed">
            The web audit and CLI are MIT-licensed and remain free forever. The CLI runs locally with
            no usage limits.
          </p>
        </div>

        <div class="flex items-center border-t border-border bg-bg-subtle p-8 lg:border-l lg:border-t-0">
          <MonitorSurface variant="light" class="w-full" />
        </div>
      </div>
      <div class="grid border-t border-border bg-bg-base md:grid-cols-4">
        {[
          ['Free', 'Audit once, learn what to fix.'],
          ['Pro', 'Track one domain weekly.'],
          ['Studio', 'Run a portfolio daily.'],
          ['Agency', 'Add team and bulk workflows.'],
        ].map(([label, text]) => (
          <div class="border-b border-border p-5 md:border-b-0 md:border-r md:last:border-r-0">
            <p class="font-mono text-xs uppercase tracking-[0.16em] text-accent-teal">{label}</p>
            <p class="mt-2 text-sm leading-relaxed text-text-secondary">{text}</p>
          </div>
        ))}
      </div>
    </header>

    {/* Credibility row — verifiable signals only (open-source, research-backed, coverage) */}
    <section aria-label="What the audit is built on" class="mb-16 -mt-8">
      <ul class="grid gap-px overflow-hidden rounded-[--radius-lg] border border-border bg-border sm:grid-cols-2 lg:grid-cols-4">
        {[
          ['Open source, MIT', 'Scoring weights are public and auditable on GitHub.'],
          ['Research-grounded', 'Weights follow Princeton KDD 2024 and AutoGEO ICLR 2026.'],
          ['27 AI bots checked', 'robots.txt access verified across 27 AI crawlers.'],
          ['47 citability methods', 'Each audit runs 47 citation-signal checks.'],
        ].map(([label, text]) => (
          <li class="bg-bg-surface p-5">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.14em] text-accent-teal">{label}</p>
            <p class="mt-2 text-sm leading-relaxed text-text-secondary">{text}</p>
          </li>
        ))}
      </ul>
    </section>

    {/* Plan cards */}
    <section aria-labelledby="plans-heading">
      <h2 id="plans-heading" class="sr-only">Plans</h2>

      <p class="mb-6 text-xs text-text-muted font-mono">
        Founding price for early members — locked for life while your subscription stays active.
      </p>

      {/* Self-serve row */}
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
        {selfServePlans.map((plan) => (
          <div class={`relative flex flex-col p-6 rounded-[--radius-lg] border bg-bg-surface ${plan.recommended ? 'border-accent-teal ring-1 ring-accent-teal/20' : 'border-border'}`}>
            {plan.recommended && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="px-3 py-1 text-[10px] font-mono font-semibold uppercase tracking-wider bg-accent-teal text-white rounded-full whitespace-nowrap">
                  Recommended
                </span>
              </div>
            )}

            <div class="mb-4">
              <div class="flex items-center justify-between mb-3">
                <span class="text-sm font-semibold text-text-primary font-mono">{plan.name}</span>
                <span class={`text-[10px] font-mono uppercase tracking-wider px-2 py-0.5 rounded-full ${plan.statusStyle}`}>
                  {plan.status}
                </span>
              </div>
              <div class="flex items-baseline gap-1">
                <span class="font-display text-3xl font-bold text-text-primary">{plan.price}</span>
                {plan.period && <span class="text-sm text-text-muted">{plan.period}</span>}
              </div>
              <p class="mt-3 text-sm text-text-secondary leading-relaxed">{plan.description}</p>
            </div>

            <ul class="flex-1 space-y-2 mb-6">
              {plan.features.map((f) => (
                <li class="flex items-start gap-2 text-sm text-text-secondary">
                  <svg aria-hidden="true" class="mt-0.5 w-3.5 h-3.5 shrink-0 text-accent-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            <a
              href={plan.ctaHref}
              data-plan-id={plan.id}
              data-plan-name={plan.name}
              data-plan-price={plan.price}
              data-plan-period={plan.period}
              data-plan-currency="USD"
              data-cta-location="pricing_page"
              class={`block text-center py-2.5 px-4 rounded-[--radius-md] text-sm font-semibold transition-colors ${plan.ctaStyle}`}
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>

      {/* Scale row */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {scalePlans.map((plan) => (
          <div class="flex flex-col p-6 rounded-[--radius-lg] border border-border bg-bg-surface">
            <div class="mb-4">
              <div class="flex items-center justify-between mb-3">
                <span class="text-sm font-semibold text-text-primary font-mono">{plan.name}</span>
                <span class={`text-[10px] font-mono uppercase tracking-wider px-2 py-0.5 rounded-full ${plan.statusStyle}`}>
                  {plan.status}
                </span>
              </div>
              <div class="flex items-baseline gap-1">
                <span class="font-display text-3xl font-bold text-text-primary">{plan.price}</span>
                {plan.period && <span class="text-sm text-text-muted">{plan.period}</span>}
              </div>
              <p class="mt-3 text-sm text-text-secondary leading-relaxed">{plan.description}</p>
            </div>

            <ul class="flex-1 space-y-2 mb-6">
              {plan.features.map((f) => (
                <li class="flex items-start gap-2 text-sm text-text-secondary">
                  <svg aria-hidden="true" class="mt-0.5 w-3.5 h-3.5 shrink-0 text-accent-teal" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            {/* Enterprise è lead-gen ("Contact sales"), non selezione piano self-serve:
                usa data-cta → geo_cta_clicked, non data-plan-id → geo_plan_selected. */}
            {plan.id === 'enterprise' ? (
              <a
                href={plan.ctaHref}
                data-cta="pricing_enterprise_contact_sales"
                class="block text-center py-2.5 px-4 rounded-[--radius-md] text-sm font-semibold border border-border text-text-primary hover:bg-bg-subtle transition-colors"
              >
                {plan.cta}
              </a>
            ) : (
              <a
                href={plan.ctaHref}
                data-plan-id={plan.id}
                data-plan-name={plan.name}
                data-plan-price={plan.price}
                data-plan-period={plan.period}
                data-plan-currency="USD"
                data-cta-location="pricing_page"
                class="block text-center py-2.5 px-4 rounded-[--radius-md] text-sm font-semibold border border-border text-text-primary hover:bg-bg-subtle transition-colors"
              >
                {plan.cta}
              </a>
            )}
          </div>
        ))}
      </div>
    </section>

    {/* Free vs Pro */}
    <section class="mt-20 md:mt-24" aria-labelledby="free-vs-pro-heading">
      <h2 id="free-vs-pro-heading" class="font-display text-2xl font-bold text-text-primary mb-2">
        Free vs Pro — what changes
      </h2>
      <p class="text-sm text-text-secondary mb-8 max-w-2xl">
        The free audit is a single-URL, point-in-time snapshot. Pro turns it into an ongoing signal.
      </p>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-[--radius-lg] border border-border bg-bg-surface">
          <span class="text-xs font-mono font-semibold text-text-muted uppercase tracking-wider px-2 py-0.5 rounded-full bg-bg-subtle border border-border inline-block mb-4">
            Free — available now
          </span>
          <ul class="space-y-3 text-sm text-text-secondary">
            <li class="flex items-start gap-2.5">
              <span class="mt-0.5 text-accent-teal shrink-0">✓</span>
              Full GEO score (0–100) for any public URL
            </li>
            <li class="flex items-start gap-2.5">
              <span class="mt-0.5 text-accent-teal shrink-0">✓</span>
              3 of 8 category breakdowns (robots, meta, signals)
            </li>
            <li class="flex items-start gap-2.5">
              <span class="mt-0.5 text-accent-teal shrink-0">✓</span>
              Top 3 actionable recommendations
            </li>
            <li class="flex items-start gap-2.5">
              <span class="mt-0.5 text-accent-teal shrink-0">✓</span>
              Up to 5 audits per day, no account needed
            </li>
            <li class="flex items-start gap-2.5">
              <span class="mt-0.5 text-accent-teal shrink-0">✓</span>
              CLI unlimited via pip (MIT license, forever)
            </li>
          </ul>
        </div>
        <div class="p-6 rounded-[--radius-lg] border border-accent-teal/30 bg-bg-surface">
          <span class="text-xs font-mono font-semibold text-accent-teal uppercase tracking-wider px-2 py-0.5 rounded-full bg-accent-teal/10 inline-block mb-4">
            Pro — founding price
          </span>
          <ul class="space-y-3 text-sm text-text-secondary">
            <li class="flex items-start gap-2.5">
              <span class="mt-0.5 text-accent-teal shrink-0">+</span>
              Full 8-category report (all signals, all categories)
            </li>
            <li class="flex items-start gap-2.5">
              <span class="mt-0.5 text-accent-teal shrink-0">+</span>
              Weekly monitoring — score tracked automatically
            </li>
            <li class="flex items-start gap-2.5">
              <span class="mt-0.5 text-accent-teal shrink-0">+</span>
              Score history — 30 audits, see trends over time
            </li>
            <li class="flex items-start gap-2.5">
              <span class="mt-0.5 text-accent-teal shrink-0">+</span>
              Regression alerts — notified when your score moves by 5 points or more
            </li>
            <li class="flex items-start gap-2.5">
              <span class="mt-0.5 text-accent-teal shrink-0">+</span>
              PDF export + API access (Bearer token)
            </li>
          </ul>
        </div>
      </div>
    </section>

    {/* Why not a traditional SEO tool? */}
    <section class="mt-20 md:mt-24" aria-labelledby="geo-vs-seo-heading">
      <h2 id="geo-vs-seo-heading" class="font-display text-2xl font-bold text-text-primary mb-2">
        Why not a traditional SEO tool?
      </h2>
      <p class="text-sm text-text-secondary mb-8 max-w-2xl">
        SEO tools measure ranking signals. GEO Optimizer measures citation signals — a different question entirely.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="p-5 rounded-[--radius-lg] border border-border bg-bg-surface">
          <p class="text-sm font-semibold text-text-primary mb-2">Ranking vs. being cited</p>
          <p class="text-sm text-text-secondary leading-relaxed">
            Traditional SEO predicts whether Google ranks your page. GEO predicts whether ChatGPT,
            Perplexity, or Claude cites your content in an answer. These are correlated but not the same.
          </p>
        </div>
        <div class="p-5 rounded-[--radius-lg] border border-border bg-bg-surface">
          <p class="text-sm font-semibold text-text-primary mb-2">Different signal set</p>
          <p class="text-sm text-text-secondary leading-relaxed">
            GEO audits llms.txt, ai.txt, JSON-LD depth, factual density, brand entity coherence,
            and AI-crawler permissions — signals that SEO tools don't surface.
          </p>
        </div>
        <div class="p-5 rounded-[--radius-lg] border border-border bg-bg-surface">
          <p class="text-sm font-semibold text-text-primary mb-2">Research-backed scoring</p>
          <p class="text-sm text-text-secondary leading-relaxed">
            Scoring weights are grounded in <a href="/research/" class="text-accent-teal hover:underline">Princeton KDD 2024 and AutoGEO ICLR 2026</a> research
            on what actually influences AI search retrieval.
          </p>
        </div>
        <div class="p-5 rounded-[--radius-lg] border border-border bg-bg-surface">
          <p class="text-sm font-semibold text-text-primary mb-2">Open source and auditable</p>
          <p class="text-sm text-text-secondary leading-relaxed">
            Every scoring rule is readable in the <a href="https://github.com/Auriti-Labs/geo-optimizer-skill" target="_blank" rel="noopener" class="text-accent-teal hover:underline">public repository</a>.
            No black box — you can audit the auditor.
          </p>
        </div>
        <div class="p-5 rounded-[--radius-lg] border border-border bg-bg-surface">
          <p class="text-sm font-semibold text-text-primary mb-2">Forward-looking signals</p>
          <p class="text-sm text-text-secondary leading-relaxed">
            llms.txt and ai.txt are emerging standards. GEO tracks adoption curves and updates scoring
            weights as the AI search landscape evolves.
          </p>
        </div>
        <div class="p-5 rounded-[--radius-lg] border border-border bg-bg-surface">
          <p class="text-sm font-semibold text-text-primary mb-2">Complements, doesn't replace</p>
          <p class="text-sm text-text-secondary leading-relaxed">
            Use GEO Optimizer alongside your existing SEO tooling. A strong GEO score makes a well-ranked
            page more likely to be cited by AI assistants.
          </p>
        </div>
      </div>
    </section>

    {/* Feature comparison table */}
    <section class="mt-20 md:mt-24" aria-labelledby="comparison-heading">
      <h2 id="comparison-heading" class="font-display text-2xl font-bold text-text-primary mb-2">
        Feature comparison
      </h2>
      <p class="text-sm text-text-secondary mb-8">
        Items marked "roadmap" are planned and not yet available. Everything else is live today.
      </p>
      <div class="overflow-x-auto -mx-4 sm:mx-0">
        <table class="w-full text-sm border-collapse min-w-[480px] px-4 sm:px-0">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left py-3 pr-4 font-medium text-text-muted font-mono text-xs uppercase tracking-wider w-[40%]">Feature</th>
              <th class="text-center py-3 px-3 font-medium text-text-muted font-mono text-xs uppercase tracking-wider">Free</th>
              <th class="text-center py-3 px-3 font-medium text-accent-teal font-mono text-xs uppercase tracking-wider">Pro</th>
